# =============================================================================
# Worker — Cloudflare resource IDs (Build env on Workers Git deploy, or local .env)
# Used by scripts/generate-wrangler.mjs → wrangler.toml (gitignored, generated)
# =============================================================================
D1_DATABASE_ID=
KV_NAMESPACE_ID=
# Optional:
# WORKER_NAME=page-speed-tester-api
# CRON_EXPRESSION=*/5 * * * *

# =============================================================================
# Worker — secrets (Cloudflare Worker → Secrets, or wrangler secret put)
# =============================================================================
SESSION_SECRET=change-me-to-a-long-random-string
GH_PAT=
WORKER_API_SECRET=change-me-to-another-random-string

# =============================================================================
# Worker — optional [vars] fallback (prefer Admin → Instance settings in D1)
# =============================================================================
GH_OWNER=
GH_REPO=
COOKIE_DOMAIN=
# Demo/template source instance: set to upstream (disables Admin → Upstream sync)
# PST_INSTANCE_ROLE=upstream
# Optional: comma-separated dashboard origins for CORS (full URLs), if not covered by api.* rule
DASHBOARD_ORIGIN=

# =============================================================================
# Pages — build environment variable (NOT the Worker!)
# Cloudflare Pages → Settings → Environment variables → Build
# Read only by scripts/dashboard/prepare-dashboard.mjs during the Pages build.
# =============================================================================
# Optional at build time. Custom domain: browser fallback https://api.<dashboard-host> if unset.
# Required for *.pages.dev / *.workers.dev (Worker URL not derivable from Pages hostname):
PST_API_URL=https://api.page-speed-tester.mydomain.tld

# =============================================================================
# GitHub Actions — repository secrets (optional in local .env for scripts)
# =============================================================================
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=page-speed-tester-reports
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
WORKER_API_URL=https://api.page-speed-tester.mydomain.tld
# or WORKER_API_URL=https://page-speed-tester.<account>.workers.dev
